# Copy this file to ".env" for local testing, and set the same values
# in Render's "Environment" tab when you deploy.

# Your MongoDB Atlas connection string (Atlas -> Connect -> Drivers).
# Replace <password> with your DB user password and keep the db name (e.g. /dcal).
MONGODB_URI=mongodb+srv://USERNAME:<password>@cluster0.xxxxx.mongodb.net/dcal?retryWrites=true&w=majority

# The password you type to open the admin dashboard (html/admin.html).
ADMIN_PASSWORD=change-this-to-a-strong-password

# Port (Render sets this automatically; leave as-is for local testing).
PORT=3000
